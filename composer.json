{
    "name": "everypay/task",
    "description": "EveryPay pre-employment PHP project",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lefteris\\EverypayTask\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lefteris\\EverypayTask\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Lefteris Messanakis",
            "email": "e.messanakis@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.5",
        "ramsey/uuid": "^4.7",
        "symfony/console": "^7.0",
        "symfony/mailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
